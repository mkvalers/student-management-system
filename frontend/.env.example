# ---------------------------------------------------------------------------
# .env.development  — used automatically during `npm run dev`
# ---------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8080


# ---------------------------------------------------------------------------
# .env.production   — used automatically during `npm run build`
# ---------------------------------------------------------------------------
VITE_API_BASE_URL=https://api.yourdomain.com

# In development Axios proxies through Vite (/api → VITE_API_BASE_URL).
# In production Axios calls VITE_API_BASE_URL directly.
